@model CarService.Mvc.ViewModels.PagedResultVm<CarService.Mvc.Models.Repair>
@using CarService.Mvc.Models

@{
    Layout = "_Layout";

    var status = (RepairStatus?)ViewBag.Status;
    var plateNumber = (string?)ViewBag.PlateNumber;
    var isPaid = (bool?)ViewBag.IsPaid;
    var startFrom = (string?)ViewBag.StartDateFrom;
    var startTo = (string?)ViewBag.StartDateTo;

    var vehicles = ViewBag.Vehicles as List<Vehicle> ?? new List<Vehicle>();
    var vehiclePlates = vehicles.ToDictionary(v => v.Id, v => v.PlateNumber);

    int totalPages = (int)Math.Ceiling((double)Model.TotalCount / Math.Max(1, Model.PageSize));
}

<div class="d-flex justify-content-between align-items-center">
    <h3>Repairs</h3>
    <a class="btn btn-success" asp-action="Create">Create</a>
</div>

<form method="get" class="row g-2 mt-2">
    <div class="col-md-2">
        <select class="form-select" name="status">
            <option value="">Status...</option>
            @foreach (var s in Enum.GetValues(typeof(RepairStatus)).Cast<RepairStatus>())
            {
                var selected = status.HasValue && status.Value == s ? "selected" : "";
                <option value="@((int)s)" selected="@selected">@s</option>
            }
        </select>
    </div>

    <div class="col-md-2">
        <input class="form-control" name="plateNumber" value="@(plateNumber ?? "")" placeholder="Plate Number" />
    </div>

    <div class="col-md-2">
        <select class="form-select" name="isPaid">
            <option value="">Paid</option>
            <option value="true" selected="@(isPaid == true)">Yes</option>
            <option value="false" selected="@(isPaid == false)">No</option>
        </select>
    </div>

    <div class="col-md-2">
        <input type="date" class="form-control" name="startDateFrom" value="@startFrom" />
    </div>

    <div class="col-md-2">
        <input type="date" class="form-control" name="startDateTo" value="@startTo" />
    </div>

    <div class="col-md-1">
        <button class="btn btn-primary w-100">Go</button>
    </div>
    <div class="col-md-1">
        <a class="btn btn-outline-secondary w-100" asp-action="Index">X</a>
    </div>
</form>

<table class="table table-striped mt-3">
    <thead>
        <tr>
            <th>Id</th>
            <th>Plate Number</th>
            <th>Title</th>
            <th>Status</th>
            <th>Hours</th>
            <th>Parts</th>
            <th>Total (ˆ)</th> 
            <th>Paid</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var r in Model.Items)
        {
            <tr>
                <td>@r.Id</td>
                <td>@(vehiclePlates.TryGetValue(r.VehicleId, out var plate) ? plate : $"#{r.VehicleId}")</td>
                <td>@r.Title</td>
                <td>@r.Status</td>
                <td>@r.LaborHours</td>
                <td>@r.PartsCost</td>

                <td>@(((decimal)r.LaborHours * 20m + r.PartsCost).ToString("0.00"))</td>

                <td>
                    @if (r.IsPaid)
                    {
                        <span class="badge bg-success">Yes</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">No</span>
                    }
                </td>
                <td class="text-end">
                    <a class="btn btn-sm btn-info"
                       asp-controller="RepairDocuments"
                       asp-action="Index"
                       asp-route-repairId="@r.Id">Documents</a>

                    <a class="btn btn-sm btn-warning"
                       asp-action="Edit"
                       asp-route-id="@r.Id">Edit</a>

                    <a class="btn btn-sm btn-danger"
                       asp-action="Delete"
                       asp-route-id="@r.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (totalPages > 1)
{
    <nav>
        <ul class="pagination">
            @for (int p = 1; p <= totalPages; p++)
            {
                var active = p == Model.Page ? "active" : "";
                <li class="page-item @active">
                    <a class="page-link"
                       href="@Url.Action("Index", new { status, plateNumber, isPaid, startDateFrom = startFrom, startDateTo = startTo, page = p, pageSize = Model.PageSize })">@p</a>
                </li>
            }
        </ul>
    </nav>
}